{
    "name": "Sqeleton Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/sqeleton,type=bind",
    "workspaceFolder": "/workspace/sqeleton",
    "customizations": {
        "vscode": {
            "settings": {
                "python.terminal.activateEnvironment": false
            },
            "extensions": [
                "ms-python.python"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "installOhMyBash": true,
            "upgradePackages": false,
            "username": "automatic",
            "uid": "automatic",
            "gid": "automatic"
        }
    }
}